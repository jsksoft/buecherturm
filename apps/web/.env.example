# Supabase (EU Frankfurt)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role (server-only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (server-only, PgBouncer/transaction-pooler compatible)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres?pgbouncer=true

# AES-256-GCM encryption key (GDPR requirement — min 32 chars)
ENCRYPTION_SECRET=change-me-to-a-random-32-char-minimum-secret

# AI Providers (server-only)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
